# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Bring-your-own-key AI (per-user). Each user supplies their own LLM API key
# at signup via /dashboard/setup; the key is encrypted with AES-256-GCM before
# being stored. Set AI_KEY_ENCRYPTION_SECRET to a random 32-byte value — e.g.
# `openssl rand -base64 32`. Changing it will invalidate all existing keys.
AI_KEY_ENCRYPTION_SECRET=your_base64_32byte_secret

# OpenAI Whisper (voice transcription only — optional)
# Voice features require this shared key because not every supported LLM
# provider offers Whisper. If unset, voice is disabled for all users.
OPENAI_WHISPER_KEY=your_openai_api_key

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# App
NEXTAUTH_SECRET=your_random_secret_32_chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron — shared secret used to authenticate /api/cron/sync invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_cron_secret

# Outlook (Future - placeholder)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback
