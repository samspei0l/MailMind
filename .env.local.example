# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NVIDIA NIM (used for all LLM calls via OpenAI-compatible API)
NVIDIA_API_KEY=nvapi-your_key_here

# OpenAI Whisper (voice transcription only — optional)
OPENAI_WHISPER_KEY=your_openai_api_key

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# App
NEXTAUTH_SECRET=your_random_secret_32_chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron — shared secret used to authenticate /api/cron/sync invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_cron_secret

# Outlook (Future - placeholder)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback
